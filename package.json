        "upgrade:diamond:sepolia": "DEPLOY_NETWORK=sepolia node scripts/runWithNetwork.js scripts/upgradeDiamond.js",
        "upgrade:facet": "npx hardhat run scripts/upgradeFacets.js --network sepolia",
